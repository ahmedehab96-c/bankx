# BankX — Production Environment
# Companion to config/env/production.json
# All secrets via GitHub Secrets / secure vault — never commit values here.

BANKX_ENV=production
BANKX_API_BASE_URL=https://api.bankx.com/v1

FIREBASE_CONFIGURED=true
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_API_KEY=
FIREBASE_PROJECT_ID=

BANKX_ENABLE_ANALYTICS=true
BANKX_ENABLE_CRASHLYTICS=true
BANKX_ENABLE_BIOMETRIC=true
BANKX_ENABLE_OFFLINE_SYNC=true
