# BankX environment secrets template
# Copy to .env.local (gitignored) for local overrides — NEVER commit secrets.

# API
BANKX_API_BASE_URL=https://api-dev.bankx.com/v1

# Firebase (set FIREBASE_CONFIGURED=true after flutterfire configure)
FIREBASE_CONFIGURED=false
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_API_KEY=
FIREBASE_PROJECT_ID=

# Feature flags
BANKX_ENABLE_ANALYTICS=true
BANKX_ENABLE_CRASHLYTICS=false
BANKX_ENABLE_BIOMETRIC=true
BANKX_ENABLE_OFFLINE_SYNC=true

# Android signing (CI: GitHub Secrets)
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# iOS signing (CI: GitHub Secrets / Match)
IOS_DISTRIBUTION_CERTIFICATE=
IOS_PROVISIONING_PROFILE=

# Firebase App Distribution
FIREBASE_APP_ID_ANDROID=
FIREBASE_APP_ID_IOS=
FIREBASE_TOKEN=

# Optional: Codecov, Sentry, etc.
CODECOV_TOKEN=
